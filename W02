
class TouristPlace:
    def __init__(self, name, province, category, description):
        self.name = name
        self.province = province
        self.category = category
        self.description = description

    def show_info(self):
        print("ข้อมูลสถานที่ท่องเที่ยว")
        print("ชื่อสถานที่:", self.name)
        print("จังหวัด:", self.province)
        print("ประเภท:", self.category)
        print("รายละเอียด:", self.description)


place1 = TouristPlace(
    "เกาะช้าง",
    "ตราด",
    "เกาะ / ทะเล",
    "เป็นสถานที่ท่องเที่ยวชื่อดังของจังหวัดตราด มีชายหาดสวยงาม น้ำทะเลใส "
)

place1.show_info()